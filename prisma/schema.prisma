// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model BlogContentPlan {
  id              Int       @id @default(autoincrement())
  shop            String
  weekStart       DateTime  @db.Date
  dayIndex        Int
  scheduledDate   DateTime  @db.Date
  topic           String
  category        String
  contentFormat   String
  targetWordCount Int       @default(2000)
  keywords        String[]  @default([])
  status               String    @default("planned")
  generatingStartedAt  DateTime?
  articleId            String?
  articleUrl           String?
  publishedAt          DateTime?
  errorMessage         String?
  createdAt            DateTime  @default(now())

  @@index([shop, scheduledDate, status])
  @@index([shop, weekStart])
}

model BlogSettings {
  id          Int      @id @default(autoincrement())
  shop        String   @unique
  blogId      String   @default("")
  blogTitle   String   @default("")
  brandName   String   @default("ENCANTO")
  ctaUrl      String   @default("/pages/contact")
  servicesUrl String   @default("/pages/collections/all")
  active      Boolean  @default(false)
  testMode    Boolean  @default(false)
  extendedQAQuestions       Json @default("{}")
  extendedFashionCategories Json @default("[]")
  productLinks              Json @default("[]")
  translationEnabled Boolean  @default(false)
  translationLocales String[] @default(["ar","cs","da","de","el","es","fi","fr","hu","it","nl","no","pl","ro","ru","sk","sv","tr","uk"])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ArticleTranslation {
  id           Int       @id @default(autoincrement())
  planId       Int
  shop         String
  locale       String
  status       String    @default("pending") // pending | translating | done | failed
  attempts     Int       @default(0)
  errorMessage String?
  translatedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([planId, locale])
  @@index([shop, status])
}
